{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "maicol07/account",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.5",
    "ext-fileinfo": "*",
    "ext-intl": "*",
    "ext-pdo": "*",
    "api-platform/laravel": "^4.2",
    "emargareten/inertia-modal": "^1.5",
    "fakerphp/faker": "^1.23",
    "inertiajs/inertia-laravel": "^2.0",
    "itsgoingd/clockwork": "^5.3",
    "laravel-lang/locales": "^2.10",
    "laravel/fortify": "*",
    "laravel/framework": "^13.0",
    "laravel/horizon": "*",
    "laravel/octane": "*",
    "laravel/pail": "*",
    "laravel/pulse": "*",
    "laravel/sanctum": "*",
    "laravel/telescope": "*",
    "laravel/tinker": "*",
    "laravel/wayfinder": "^0.1.4",
    "maicol07/laravel-oidc-client": "^1.1",
    "mariusgelez/igdb-laravel": "^1.0",
    "opcodesio/log-viewer": "^3.10",
    "phpdocumentor/type-resolver": "^1.12",
    "soved/laravel-gdpr": "^1.9",
    "spatie/laravel-activitylog": "^4.10"
  },
  "require-dev": {
    "larastan/larastan": "^3.10",
    "laravel-lang/lang": "^15.26",
    "laravel-lang/publisher": "^16.7",
    "laravel/boost": "^2.0",
    "laravel/pint": "*",
    "laravel/sail": "*",
    "mockery/mockery": "*",
    "nunomaduro/collision": "*",
    "pestphp/pest": "*",
    "pestphp/pest-plugin-laravel": "*",
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    },
    "files": [
      "app/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "setup": [
      "composer install",
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
      "@php artisan key:generate",
      "@php artisan migrate --force",
      "pnpm install",
      "pnpm run build"
    ],
    "dev": [
      "Composer\\Config::disableProcessTimeout",
      "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
    ],
    "test": [
      "@php artisan config:clear --ansi",
      "@php artisan test"
    ],
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-update-cmd": [
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
      "@php artisan lang:update"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi",
      "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
      "@php artisan migrate --graceful --ansi"
    ],
    "pre-package-uninstall": [
      "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": [
        "nesbot/carbon"
      ]
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "php-http/discovery": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
